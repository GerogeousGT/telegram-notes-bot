# Скопируй в корень репо как .env и заполни своими значениями
# Либо положи значения в корневой c:\ClaudeCode\AI\.env

TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id
ASSEMBLYAI_KEY=your_assemblyai_key

# Опционально — папка для хранения данных (по умолчанию ./Распределение)
# DATA_FOLDER=/custom/path/to/data

# Опционально — включить debug-режим
# DEBUG_MODE=true

# DeepSeek API — для AI-ассистента (бесплатный tier: platform.deepseek.com)
# Без этого ключа бот работает в режиме сохранения (без AI)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
